...@styles

direction: right

title: "Phase prompt assembly" {
  near: top-center
  shape: text
  class: text
}

inputs: "Scaffold context" {
  class: lavender-zone
  answers: "Answers: stack, brief, options, demo" {class: card}
  stack: "Stack structure, libraries, commands" {class: card}
  conventions: "Compiled convention bundle" {class: data}
  design: "Design template and media manifest" {class: data}
  starter: "CLAUDE.md starter guidance" {class: muted}
  phase: "Assigned phases and provider" {class: tag}
}

safety: "Secret scan user-controlled text" {class: card}

builder: "prompt_builder.py" {
  class: lavender-zone
  ownership: "One provider owns every phase?" {shape: diamond; class: card}
  full: "Select full scaffold contract" {class: card}
  targeted: "Choose architecture, frontend,\ntests, or verify variant" {class: card}
  specialize: "Apply provider-specific wording" {class: card}
  ownership -> full: yes
  ownership -> targeted: no
  targeted -> specialize
}

phase_content: "Provider-specific\nprompt content" {class: card}

plan: "scaffold_prompts.py" {
  class: lavender-zone
  boundary: "Append Forge-owned\nruntime boundary" {class: muted}
  live: "Live prompt per routed phase" {class: accent}
  preview: "Preview per merged provider group" {class: data}
  progress: "Resumable progress records" {class: data}
  export: "Prompt-only print or export" {class: data}

  boundary -> live: routed phase
  boundary -> preview: merged group
  live -> progress
  preview -> export
}

cli_args: "Model and approval flags" {class: muted}
provider_call: "Provider CLI invocation" {class: tag}

inputs.answers -> safety
inputs.stack -> builder.ownership
inputs.conventions -> safety
inputs.design -> safety
inputs.starter -> builder.ownership
inputs.phase -> builder.ownership
safety -> builder.ownership
builder.full -> phase_content
builder.specialize -> phase_content
phase_content -> plan.boundary
plan.live -> provider_call: prompt content
cli_args -> provider_call: execution settings
