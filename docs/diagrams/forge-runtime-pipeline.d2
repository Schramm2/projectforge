...@styles

direction: down

title: "End-to-end scaffold runtime" {
  near: top-center
  shape: text
  class: text
}

entry: "CLI command" {class: tag}

prepare: "1  Prepare" {
  class: lavender-zone
  grid-rows: 2
  setup: "1  Setup if needed" {class: card}
  answers: "2  Collect or validate answers" {class: card}
  route: "3  Route phases" {class: card}
  context: "4  Load conventions, design,\nmedia, and quality" {class: card}
  safety: "5  Scan for secrets" {class: card}
  prompts: "6  Build phase prompts" {class: data}
  git: "7  Initialize live Git repo\non main" {class: card}
}

execute: "2  Execute" {
  class: lavender-zone
  grid-rows: 1
  progress: "1  Initialize resumable progress" {class: data}
  copy: "2  Copy selected media" {class: card}
  phases: "3  Run provider phases" {class: card}
}

finish: "3  Verify and hand off" {
  class: lavender-zone
  grid-rows: 2
  manifest: "1  Write manifest and snapshot" {class: data}
  verify: "2  Run generated-project checks" {class: card}
  records: "3  Write verification and quality signals" {class: data}
  hook: "4  Run optional post-scaffold hook" {class: muted}
  artifacts: "5  Write card and README badge" {class: data}
  commit: "6  Commit final generated changes" {class: card}
  dashboard: "7  Dashboard, sound, and editor" {class: accent}
}

learning: "Local learning for future runs" {
  class: lavender-zone
  grid-rows: 1
  history: "Scaffold history" {class: data}
  preferences: "Answer preferences" {class: data}
  quality: "Provider quality signals" {class: data}
}

entry -> prepare
prepare -> execute
execute -> finish
finish -> learning: records local outcomes
